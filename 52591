<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <title>William Holley | Developer</title>
  <meta name="title" content="William Holley | Developer">
  <meta name="description" content="A young developer specializing in high-performance Slack & Discord tools, JavaScript, and Automation.">
  <meta name="author" content="William Holley">

  <meta property="og:type" content="website">
  <meta property="og:url" content="https://me.will.sryze.cc/">
  <meta property="og:title" content="William Holley | Developer">
  <meta property="og:description" content="Engineering high-performance tools and automation logic.">
  <meta property="og:image" content="https://me.will.sryze.cc/favicons/apple-touch-icon.png">

  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="https://me.will.sryze.cc/">
  <meta property="twitter:title" content="William Holley | Developer">
  <meta property="twitter:description" content="Engineering high-performance tools and automation logic.">
  <meta property="twitter:image" content="https://me.will.sryze.cc/favicons/apple-touch-icon.png">
  
  <link rel="apple-touch-icon" sizes="180x180" href="favicons/apple-touch-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="favicons/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="favicons/favicon-16x16.png">
  <link rel="shortcut icon" href="favicons/favicon.ico">
  <link rel="manifest" href="favicons/site.webmanifest">
  <meta id="theme-color-meta" name="theme-color" content="#fdfcf9">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg: #fdfcf9; --surface: rgba(255, 255, 255, 0.7); --text: #1a1a1a; --muted: #64748b;
      --line: #e2e8f0; --accent: #0f172a; --r-card: 24px; 
      --t: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    [data-theme="dark"] {
      --bg: #0b0b0a; --surface: rgba(22, 22, 21, 0.7); --text: #f1f5f9; --muted: #94a3b8;
      --line: #262626; --accent: #ffffff;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; text-decoration: none !important; }
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; transition: background 0.5s ease; overflow-x: hidden; width: 100%; }
    .wrap { width: 100%; max-width: 700px; margin: 0 auto; padding: 0 clamp(1rem, 5vw, 2rem); }

    #toast {
      position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%) translateY(100px);
      background: var(--accent); color: var(--bg); padding: 12px 24px; border-radius: 50px;
      font-weight: 600; font-size: clamp(0.75rem, 2vw, 0.85rem); z-index: 3000; opacity: 0; 
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    #toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }

    header { position: sticky; top: 0; z-index: 100; background: var(--bg); backdrop-filter: blur(12px); border-bottom: 1px solid var(--line); padding: clamp(12px, 3vh, 18px) 0; }
    nav { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    #header-name { font-weight: 800; font-size: clamp(0.9rem, 4vw, 1.1rem); }
    
    .theme-switch { position: relative; width: 56px; height: 28px; background: var(--line); border-radius: 30px; cursor: pointer; display: flex; align-items: center; justify-content: space-around; font-size: 0.8rem; flex-shrink: 0; }
    .switch-handle { position: absolute; left: 3px; width: 22px; height: 22px; background: var(--accent); border-radius: 50%; transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1); }
    [data-theme="dark"] .switch-handle { transform: translateX(28px); }

    .hero { padding: clamp(40px, 10vh, 80px) 0 clamp(30px, 5vh, 50px); text-align: center; }
    .hero h1 { font-size: clamp(2rem, 12vw, 3.5rem); margin-bottom: 15px; letter-spacing: -0.06em; font-weight: 800; line-height: 1.1; }
    .bio-text { font-size: clamp(0.95rem, 3vw, 1.15rem); color: var(--muted); max-width: 550px; margin: 0 auto; }
    .bio-text b { color: var(--text); }

    .section-title { font-size: 0.75rem; text-transform: uppercase; color: var(--muted); margin: 40px 0 20px; font-weight: 800; letter-spacing: 0.12em; display: flex; align-items: center; gap: 15px; }
    .section-title::after { content: ""; flex: 1; height: 1px; background: var(--line); }

    .grid { display: grid; grid-template-columns: 1fr; gap: 16px; }
    @media (min-width: 550px) { .grid { grid-template-columns: repeat(2, 1fr); } .grid-full { grid-column: span 2; } }

    .card { background: var(--surface); border: 1px solid var(--line); padding: clamp(20px, 5vw, 28px); border-radius: var(--r-card); display: flex; flex-direction: column; cursor: pointer; transition: all 0.3s ease; backdrop-filter: blur(8px); height: 100%; }
    .card:hover { transform: translateY(-5px); border-color: var(--accent); box-shadow: 0 15px 30px rgba(0,0,0,0.08); }
    .card i { font-size: 1.8rem; margin-bottom: 15px; }
    .card h3 { font-size: clamp(1rem, 3vw, 1.1rem); margin-bottom: 6px; font-weight: 700; }
    .card p { color: var(--muted); font-size: clamp(0.85rem, 2.5vw, 0.95rem); }

    /* Icons and Colors */
    .fa-heart { color: #ff4d4d !important; }
    .fa-js { color: #f7df1e !important; }
    .fa-node-js { color: #339933 !important; }
    .fa-python { color: #3776ab !important; }
    .fa-link { color: #00bcd4 !important; }
    .fa-gears { color: #78909c !important; }
    .fa-envelope { color: #ea4335 !important; }
    .fa-github { color: var(--text) !important; }
    .fa-youtube { color: #ff0000 !important; }
    .fa-instagram { color: #e4405f !important; }
    .fa-tiktok { color: var(--text) !important; filter: drop-shadow(2px 0px 0px #25F4EE) drop-shadow(-2px 0px 0px #FE2C55); }

    .highlight-text { color: var(--accent); font-weight: 700; }
    .time-chip { font-size: 0.8rem; color: var(--muted); margin-top: 15px; display: inline-flex; align-items: center; gap: 8px; background: var(--line); padding: 6px 14px; border-radius: 50px; }

    footer { padding: 60px 0; text-align: center; }
    .socials { display: flex; justify-content: center; flex-wrap: wrap; gap: clamp(15px, 5vw, 30px); margin-bottom: 25px; }
    .socials a { font-size: clamp(1.5rem, 5vw, 1.8rem); color: var(--muted); transition: all 0.3s ease; }
    .socials a:hover { transform: translateY(-3px); opacity: 0.8; }
  </style>
</head>
<body>

  <div id="toast">Copied to clipboard!</div>

  <header>
    <div class="wrap">
      <nav>
        <span id="header-name"></span>
        <div class="theme-switch" id="js-theme-btn" aria-label="Toggle Dark Mode">
          <i class="fa-solid fa-sun"></i><i class="fa-solid fa-moon"></i>
          <div class="switch-handle"></div>
        </div>
      </nav>
    </div>
  </header>

  <main class="wrap">
    <section class="hero">
      <h1 id="js-name"></h1>
      <div class="bio-text" id="js-bio"></div>
      <div class="time-chip">
        <i class="fa-solid fa-location-dot"></i>
        <span id="local-time"></span>
      </div>
    </section>
    <div id="js-sections-container"></div>
  </main>

  <footer>
    <div class="socials" id="js-socials"></div>
    <p id="js-copyright" style="font-size: 0.8rem; color: var(--muted); font-weight: 500;"></p>
  </footer>

  <script>
    // Logic for Birthdays and Anniversaries synced to CST
    function getCSTDate() {
      const now = new Date();
      const cstString = now.toLocaleString("en-US", {timeZone: "America/Chicago"});
      return new Date(cstString);
    }

    const birthDate = new Date('2009-06-19T00:00:00');
    const anniversaryDate = new Date('2025-11-28T00:00:00');
    const todayCST = getCSTDate();

    let age = todayCST.getFullYear() - birthDate.getFullYear();
    const m = todayCST.getMonth() - birthDate.getMonth();
    if (m < 0 || (m === 0 && todayCST.getDate() < birthDate.getDate())) { age--; }

    const diffTime = todayCST.getTime() - anniversaryDate.getTime();
    const diffDays = Math.floor(diffTime / (1000 * 60 * 60 * 24));

    const DATA = {
      name: "William Holley",
      bio: `I'm a <b>${age}-year-old developer</b> based near Chicago, specializing in high-performance <b>Slack & Discord tools</b>. When I'm not coding, I'm with <b>Hannah</b> or staying active outdoors.`,
      sections: [
        {
          title: "Personal",
          items: [
            { title: "Hannah", desc: `The person who keeps me grounded. Together since <b>11/28/25</b>—that's <span class="highlight-text">${diffDays} days</span> and counting.`, icon: "fa-solid fa-heart", full: true }
          ]
        },
        {
          title: "Capabilities",
          items: [
            { title: "JavaScript", desc: "Dynamic interactive logic.", icon: "fa-brands fa-js" },
            { title: "Node.js", desc: "High-speed server systems.", icon: "fa-brands fa-node-js" },
            { title: "Python", desc: "Efficient data scripting.", icon: "fa-brands fa-python" },
            { title: "API Design", desc: "Clean service architecture.", icon: "fa-solid fa-link" },
            { title: "Automation", desc: "Engineering tools that work for you.", icon: "fa-solid fa-gears", full: true }
          ]
        },
        {
          title: "Contact",
          items: [ 
            { title: "Email Me", val: "william.h61909@gmail.com", type: "copy", icon: "fa-solid fa-envelope", full: true }
          ]
        }
      ],
      socials: [ 
        { link: "https://github.com/4realwilly", icon: "fa-brands fa-github" }, 
        { link: "https://youtube.com/@hannahs_boyfriend_4ever", icon: "fa-brands fa-youtube" }, 
        { link: "https://instagram.com/wholley20257750", icon: "fa-brands fa-instagram" }, 
        { link: "https://tiktok.com/@hannahsbf4ever112825", icon: "fa-brands fa-tiktok" } 
      ]
    };

    function updateTime() {
      const options = { timeZone: 'America/Chicago', hour: '2-digit', minute: '2-digit', hour12: true };
      const timeString = new Intl.DateTimeFormat('en-US', options).format(new Date());
      document.getElementById('local-time').textContent = `Local Time: ${timeString} (CST)`;
    }
    setInterval(updateTime, 1000); updateTime();

    function showToast(msg) {
      const t = document.getElementById('toast');
      t.textContent = msg; t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 2000);
    }

    document.getElementById('header-name').textContent = DATA.name;
    document.getElementById('js-name').textContent = DATA.name;
    document.getElementById('js-bio').innerHTML = DATA.bio;
    document.getElementById('js-copyright').textContent = `© ${new Date().getFullYear()} ${DATA.name}`;

    const sectionsContainer = document.getElementById('js-sections-container');
    DATA.sections.forEach(section => {
      const title = document.createElement('div'); title.className = 'section-title'; title.textContent = section.title;
      sectionsContainer.appendChild(title);
      const grid = document.createElement('div'); grid.className = 'grid';
      section.items.forEach(item => {
        const card = document.createElement('div'); 
        card.className = `card ${item.full ? 'grid-full' : ''}`;
        card.onclick = () => { if (item.type === 'copy') { navigator.clipboard.writeText(item.val); showToast(`Email Copied!`); } };
        card.innerHTML = `<i class="${item.icon}"></i><div><h3>${item.title}</h3><p>${item.desc || item.val}</p></div>`;
        grid.appendChild(card);
      });
      sectionsContainer.appendChild(grid);
    });

    DATA.socials.forEach(s => {
      const a = document.createElement('a'); a.href = s.link; a.target = "_blank"; a.className = s.icon;
      document.getElementById('js-socials').appendChild(a);
    });

    // Theme Logic with Auto-detection
    const themeBtn = document.getElementById('js-theme-btn');
    const setTheme = (theme) => {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('wh-theme', theme);
      document.getElementById('theme-color-meta').setAttribute('content', theme === 'dark' ? '#0b0b0a' : '#fdfcf9');
    };

    const savedTheme = localStorage.getItem('wh-theme');
    const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

    // Set initial theme: Saved Pref > System Pref > Default light
    if (savedTheme) {
      setTheme(savedTheme);
    } else if (systemPrefersDark) {
      setTheme('dark');
    } else {
      setTheme('light');
    }

    themeBtn.onclick = () => setTheme(document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
  </script>
</body>
</html>
